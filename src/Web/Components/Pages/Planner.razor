@page "/planner"
@rendermode InteractiveServer
@inject PlannerApiClient Api
@inject ISnackbar Snackbar

<PageTitle>Planner</PageTitle>

<h1>Production Planner</h1>

<p>Pick what you have on hand (sources) and what you want to produce (sinks). The planner expands recipes backwards and tells you how many buildings of each type you need.</p>

<MudPaper Class="pa-3 mb-3" Outlined="true">
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <MudText Typo="Typo.subtitle1" Class="mr-2">Saved plans</MudText>
        <MudSelect T="Guid?" Value="@selectedSavedPlanId" ValueChanged="OnSavedPlanSelected"
                   Placeholder="@(savedPlans.Count == 0 ? "(none saved yet)" : "Load a saved plan...")"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                   Style="min-width: 18rem;" Clearable="true">
            @foreach (var p in savedPlans)
            {
                <MudSelectItem T="Guid?" Value="@((Guid?)p.Id)">@p.Name (@p.UpdatedUtc.ToLocalTime().ToString("g"))</MudSelectItem>
            }
        </MudSelect>
        <MudTextField T="string" @bind-Value="planName"
                      Placeholder="Plan name"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Style="min-width: 14rem;" />
        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SaveCurrent" Disabled="@isSaving">
            @(selectedSavedPlanId is null ? "Save as new" : "Update")
        </MudButton>
        @if (selectedSavedPlanId is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="DeleteCurrent" Disabled="@isSaving">
                Delete
            </MudButton>
            <MudButton Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.NoteAdd"
                       OnClick="NewPlan">
                New
            </MudButton>
        }
    </div>
</MudPaper>

@if (status is { IsLoaded: false })
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-3">
        No catalogue loaded yet. <a href="settings">Point the app at your <code>Docs.json</code> in Settings</a> before planning.
    </MudAlert>
}

@if (items is null)
{
    <MudText><em>Loading catalogue...</em></MudText>
}
else
{
    <MudGrid Spacing="4">
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h5" Class="mb-2">Sources <MudText HtmlTag="span" Typo="Typo.caption" Color="Color.Default">(items/min available)</MudText></MudText>
            @foreach (var row in sources)
            {
                <div class="d-flex gap-2 mb-2 align-items-center">
                    <div class="flex-grow-1">
                        <MudAutocomplete T="CatalogItem"
                                         Value="row.Item"
                                         ValueChanged="@(i => row.Item = i)"
                                         SearchFunc="@SearchItems"
                                         ToStringFunc="@(i => i?.Name ?? string.Empty)"
                                         Placeholder="Pick item"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Dense="true"
                                         Clearable="true"
                                         CoerceText="true"
                                         CoerceValue="false"
                                         data-row-role="source">
                            <ItemTemplate Context="i">
                                <div class="d-flex align-items-center gap-2">
                                    <img src="/assets/icons/items/@(i.Id).png"
                                         onerror="this.style.visibility='hidden'"
                                         style="width: 24px; height: 24px; object-fit: contain; flex: 0 0 24px;"
                                         alt="" />
                                    <span>@i.Name</span>
                                </div>
                            </ItemTemplate>
                        </MudAutocomplete>
                    </div>
                    <MudNumericField T="decimal" @bind-Value="row.ItemsPerMinute"
                                     Min="0" Step="1m"
                                     Placeholder="items / min"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="false"
                                     Style="max-width: 10rem;" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   Variant="Variant.Outlined"
                                   OnClick="() => RemoveSource(row)"
                                   title="Remove" />
                </div>
            }
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="AddSource"
                       StartIcon="@Icons.Material.Filled.Add">
                Add source
            </MudButton>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h5" Class="mb-2">Sinks <MudText HtmlTag="span" Typo="Typo.caption" Color="Color.Default">(items/min wanted)</MudText></MudText>
            @foreach (var row in sinks)
            {
                <div class="d-flex gap-2 mb-2 align-items-center">
                    <div class="flex-grow-1">
                        <MudAutocomplete T="CatalogItem"
                                         Value="row.Item"
                                         ValueChanged="@(i => row.Item = i)"
                                         SearchFunc="@SearchItems"
                                         ToStringFunc="@(i => i?.Name ?? string.Empty)"
                                         Placeholder="Pick item"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Dense="true"
                                         Clearable="true"
                                         CoerceText="true"
                                         CoerceValue="false"
                                         data-row-role="sink">
                            <ItemTemplate Context="i">
                                <div class="d-flex align-items-center gap-2">
                                    <img src="/assets/icons/items/@(i.Id).png"
                                         onerror="this.style.visibility='hidden'"
                                         style="width: 24px; height: 24px; object-fit: contain; flex: 0 0 24px;"
                                         alt="" />
                                    <span>@i.Name</span>
                                </div>
                            </ItemTemplate>
                        </MudAutocomplete>
                    </div>
                    <MudNumericField T="decimal" @bind-Value="row.ItemsPerMinute"
                                     Min="0" Step="1m"
                                     Placeholder="items / min"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="false"
                                     Style="max-width: 10rem;" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   Variant="Variant.Outlined"
                                   OnClick="() => RemoveSink(row)"
                                   title="Remove" />
                </div>
            }
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="AddSink"
                       StartIcon="@Icons.Material.Filled.Add">
                Add sink
            </MudButton>
        </MudItem>
    </MudGrid>

    <div class="mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Compute" Disabled="@isComputing">
            @(isComputing ? "Computing..." : "Compute plan")
        </MudButton>
        @if (!string.IsNullOrEmpty(error))
        {
            <MudText HtmlTag="span" Color="Color.Error" Class="ms-3">@error</MudText>
        }
    </div>
}

@if (plan is not null)
{
    <MudDivider Class="my-4" />
    <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <MudText Typo="Typo.h4" Class="mb-0">Plan</MudText>
        @if (plan.IsFeasible)
        {
            <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.CheckCircle">Feasible</MudChip>
        }
        else
        {
            <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Warning">Missing inputs</MudChip>
        }
        @if (plan.Steps.Count > 0)
        {
            <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Bolt"
                     title="Sum of base power draw (Building.BasePowerMw × buildings). Variable-power buildings (e.g. miners) report base only.">
                @FormatPower(plan.TotalPowerMw) MW total
            </MudChip>
        }
    </div>

    @if (plan.Steps.Count == 0)
    {
        <MudText><em>No production steps required (everything covered by sources, or no targets given).</em></MudText>
    }
    else
    {
        <MudDataGrid T="StepView"
                     Items="plan.Steps"
                     Hover="true"
                     Striped="true"
                     Dense="true"
                     SortMode="SortMode.Multiple"
                     Class="fx-plan-grid">
            <Columns>
                <PropertyColumn Property="s => s.RecipeName" Title="Recipe" />
                <PropertyColumn Property="s => s.BuildingName" Title="Building" />
                <PropertyColumn Property="s => s.BuildingCount" Title="Buildings" Format="0.##" CellStyle="text-align: right;" HeaderStyle="text-align: right;" />
                <PropertyColumn Property="s => s.PowerMw" Title="Power (MW)" Format="0.##" CellStyle="text-align: right;" HeaderStyle="text-align: right;" />
                <TemplateColumn Title="Inputs / min" Sortable="false" Filterable="false">
                    <CellTemplate>
                        <div class="fx-amount-list">
                            @foreach (var a in context.Item.Inputs)
                            {
                                <span class="fx-amount" title="@a.ItemName">
                                    <img src="/assets/icons/items/@(a.ItemId).png"
                                         onerror="this.style.visibility='hidden'"
                                         alt="" />
                                    <span class="fx-amount-text">@FormatRate(a.ItemsPerMinute) @a.ItemName</span>
                                </span>
                            }
                        </div>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Outputs / min" Sortable="false" Filterable="false">
                    <CellTemplate>
                        <div class="fx-amount-list">
                            @foreach (var a in context.Item.Outputs)
                            {
                                <span class="fx-amount" title="@a.ItemName">
                                    <img src="/assets/icons/items/@(a.ItemId).png"
                                         onerror="this.style.visibility='hidden'"
                                         alt="" />
                                    <span class="fx-amount-text">@FormatRate(a.ItemsPerMinute) @a.ItemName</span>
                                </span>
                            }
                        </div>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    }

    @if (plan.RawInputsConsumed.Count > 0)
    {
        <MudText Typo="Typo.h5" Class="mt-4 mb-2">Raw inputs consumed (from sources)</MudText>
        <div class="fx-amount-list">
            @foreach (var amount in plan.RawInputsConsumed)
            {
                <span class="fx-amount" title="@amount.ItemName">
                    <img src="/assets/icons/items/@(amount.ItemId).png"
                         onerror="this.style.visibility='hidden'"
                         alt="" />
                    <span class="fx-amount-text">@FormatRate(amount.ItemsPerMinute) @amount.ItemName / min</span>
                </span>
            }
        </div>
    }

    @if (plan.MissingInputs.Count > 0)
    {
        <MudText Typo="Typo.h5" Color="Color.Error" Class="mt-4 mb-1">Missing inputs</MudText>
        <MudText Typo="Typo.caption" Color="Color.Default" Class="d-block mb-2">No recipe and no source available.</MudText>
        <div class="fx-amount-list">
            @foreach (var amount in plan.MissingInputs)
            {
                <span class="fx-amount fx-amount-missing" title="@amount.ItemName">
                    <img src="/assets/icons/items/@(amount.ItemId).png"
                         onerror="this.style.visibility='hidden'"
                         alt="" />
                    <span class="fx-amount-text">@FormatRate(amount.ItemsPerMinute) @amount.ItemName / min</span>
                </span>
            }
        </div>
    }
}

@code {
    private CatalogItem[]? items;
    private CatalogueStatusView? status;
    private List<Row> sources = [new()];
    private List<Row> sinks = [new()];
    private PlanResponse? plan;
    private string? error;
    private bool isComputing;

    // Saved plans state (#77)
    private List<SavedPlanSummary> savedPlans = [];
    private Guid? selectedSavedPlanId;
    private string planName = string.Empty;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        status = await Api.GetCatalogueStatusAsync();
        items = await Api.GetItemsAsync();
        await RefreshSavedPlansAsync();
    }

    private async Task RefreshSavedPlansAsync()
    {
        try
        {
            savedPlans = (await Api.ListSavedPlansAsync()).ToList();
        }
        catch (Exception ex)
        {
            error = $"Failed to list saved plans: {ex.Message}";
        }
    }

    private void AddSource() => sources.Add(new());
    private void RemoveSource(Row row) => sources.Remove(row);
    private void AddSink() => sinks.Add(new());
    private void RemoveSink(Row row) => sinks.Remove(row);

    private async Task Compute()
    {
        error = null;
        plan = null;
        isComputing = true;
        try
        {
            var request = new PlanRequest(
                Targets:   sinks  .Where(r => r.Item is not null).Select(r => new TargetInput(r.Item!.Id, r.ItemsPerMinute)).ToList(),
                Available: sources.Where(r => r.Item is not null).Select(r => new AvailabilityInput(r.Item!.Id, r.ItemsPerMinute)).ToList());

            if (request.Targets.Count == 0)
            {
                error = "Add at least one sink.";
                return;
            }

            plan = await Api.ComputePlanAsync(request);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isComputing = false;
        }
    }

    private static string FormatRate(decimal rate) =>
        rate == Math.Floor(rate) ? rate.ToString("0") : rate.ToString("0.##");

    private static string FormatPower(decimal mw) =>
        mw == Math.Floor(mw) ? mw.ToString("0") : mw.ToString("0.##");

    private Task<IEnumerable<CatalogItem>> SearchItems(string? value, CancellationToken ct)
    {
        if (items is null) return Task.FromResult<IEnumerable<CatalogItem>>([]);
        if (string.IsNullOrWhiteSpace(value)) return Task.FromResult<IEnumerable<CatalogItem>>(items);
        var hits = items.Where(i => i.Name.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(hits);
    }

    private sealed class Row
    {
        public CatalogItem? Item { get; set; }
        public decimal ItemsPerMinute { get; set; }
    }

    // ----- Saved plans (#77) ------------------------------------------------

    private async Task OnSavedPlanSelected(Guid? id)
    {
        selectedSavedPlanId = id;
        if (id is null)
        {
            // User cleared the selection — leave rows untouched but reset name.
            return;
        }

        try
        {
            var detail = await Api.GetSavedPlanAsync(id.Value);
            if (detail is null)
            {
                error = "Selected plan not found.";
                await RefreshSavedPlansAsync();
                return;
            }

            planName = detail.Name;
            sources = detail.Available
                .Select(a => new Row { Item = items?.FirstOrDefault(i => i.Id == a.ItemId), ItemsPerMinute = a.ItemsPerMinute })
                .ToList();
            if (sources.Count == 0) sources.Add(new());
            sinks = detail.Targets
                .Select(t => new Row { Item = items?.FirstOrDefault(i => i.Id == t.ItemId), ItemsPerMinute = t.ItemsPerMinute })
                .ToList();
            if (sinks.Count == 0) sinks.Add(new());
            plan = null;
            error = null;
        }
        catch (Exception ex)
        {
            error = $"Failed to load plan: {ex.Message}";
        }
    }

    private async Task SaveCurrent()
    {
        if (string.IsNullOrWhiteSpace(planName))
        {
            error = "Enter a name before saving.";
            return;
        }

        isSaving = true;
        error = null;
        try
        {
            var input = new SavePlanInput(
                Name: planName.Trim(),
                Targets:   sinks  .Where(r => r.Item is not null).Select(r => new TargetInput(r.Item!.Id, r.ItemsPerMinute)).ToList(),
                Available: sources.Where(r => r.Item is not null).Select(r => new AvailabilityInput(r.Item!.Id, r.ItemsPerMinute)).ToList());

            SavedPlanDetail? result;
            if (selectedSavedPlanId is Guid existing)
            {
                result = await Api.UpdateSavedPlanAsync(existing, input);
                Snackbar.Add($"Updated '{input.Name}'.", Severity.Success);
            }
            else
            {
                result = await Api.CreateSavedPlanAsync(input);
                selectedSavedPlanId = result?.Id;
                Snackbar.Add($"Saved '{input.Name}'.", Severity.Success);
            }
            await RefreshSavedPlansAsync();
        }
        catch (Exception ex)
        {
            error = $"Save failed: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteCurrent()
    {
        if (selectedSavedPlanId is not Guid id) return;
        isSaving = true;
        try
        {
            var ok = await Api.DeleteSavedPlanAsync(id);
            if (ok)
            {
                Snackbar.Add($"Deleted '{planName}'.", Severity.Info);
                selectedSavedPlanId = null;
                planName = string.Empty;
            }
            else
            {
                error = "Delete failed.";
            }
            await RefreshSavedPlansAsync();
        }
        catch (Exception ex)
        {
            error = $"Delete failed: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void NewPlan()
    {
        selectedSavedPlanId = null;
        planName = string.Empty;
        sources = [new()];
        sinks = [new()];
        plan = null;
        error = null;
    }
}
